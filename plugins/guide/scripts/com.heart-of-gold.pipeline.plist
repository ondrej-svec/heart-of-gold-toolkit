<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Label: unique identifier for this launchd job -->
    <key>Label</key>
    <string>com.heart-of-gold.pipeline</string>

    <!-- ProgramArguments: headless Claude runs the pipeline skill -->
    <!-- Update the path to your claude CLI binary -->
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/claude</string>
        <string>-p</string>
        <string>Run /guide:pipeline to generate today's daily brief and content drafts. Use the lock file at content/pipeline/.pipeline.lock to prevent concurrent runs — if the lock file exists, skip this run.</string>
        <string>--allowedTools</string>
        <string>Bash,Read,Write,Edit,Glob,Grep,WebFetch,WebSearch</string>
        <string>--model</string>
        <string>sonnet</string>
    </array>

    <!-- Schedule: run daily at 2:00 AM -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>2</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Working directory: your project root (update this) -->
    <key>WorkingDirectory</key>
    <string>/Users/USER/projects/PROJECT</string>

    <!-- Log output -->
    <key>StandardOutPath</key>
    <string>content/logs/pipeline-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>content/logs/pipeline-stderr.log</string>

    <!-- Environment: ensure all tools are on PATH (update for your system) -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/USER</string>
    </dict>

    <!-- Don't run on load — only run on schedule -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
