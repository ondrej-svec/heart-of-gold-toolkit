{
  "name": "@heart-of-gold/toolkit",
  "version": "0.1.49",
  "type": "module",
  "description": "Cross-platform installer for Heart of Gold skills \u2014 works with Codex, OpenCode, Pi, Claude Code, and more",
  "bin": {
    "heart-of-gold": "src/index.ts"
  },
  "scripts": {
    "check:publish-safety": "python3 scripts/check-publish-safety.py",
    "check:security": "python3 scripts/check-security-regressions.py",
    "check:compat": "python3 scripts/check-harness-compatibility.py",
    "test:pi-guided": "node --test tests/pi-guided-workflows.test.mjs",
    "test:visualize": "node --test tests/visualize-smart-render.test.mjs",
    "release": "node scripts/release.mjs",
    "prepublishOnly": "npm run check:publish-safety && npm run check:compat"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "js-yaml": "^4.1.0"
  },
  "license": "MIT",
  "author": {
    "name": "Ondrej Svec",
    "url": "https://github.com/ondrej-svec"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ondrej-svec/heart-of-gold-toolkit.git"
  },
  "homepage": "https://github.com/ondrej-svec/heart-of-gold-toolkit",
  "keywords": [
    "codex",
    "claude-code",
    "opencode",
    "pi",
    "pi-package",
    "ai-agents",
    "skills",
    "agents-md",
    "agentskills",
    "harness-engineering",
    "heart-of-gold"
  ],
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/pi"
    ],
    "skills": [
      "./plugins/babel-fish/skills/audio",
      "./plugins/babel-fish/skills/image",
      "./plugins/babel-fish/skills/visualize",
      "./plugins/deep-thought/skills/architect",
      "./plugins/deep-thought/skills/architecture-review",
      "./plugins/deep-thought/skills/craft-skill",
      "./plugins/deep-thought/skills/cto",
      "./plugins/deep-thought/skills/investigate",
      "./plugins/deep-thought/skills/review",
      "./plugins/deep-thought/skills/think",
      "./plugins/guide/skills/capture",
      "./plugins/guide/skills/claude-code",
      "./plugins/guide/skills/codex",
      "./plugins/guide/skills/gemini",
      "./plugins/guide/skills/pipeline",
      "./plugins/guide/skills/setup",
      "./plugins/guide/skills/write-post",
      "./plugins/marvin/skills/compound",
      "./plugins/marvin/skills/harness-up",
      "./plugins/marvin/skills/share-html",
      "./plugins/marvin/skills/share-server-control",
      "./plugins/marvin/skills/share-server-setup",
      "./plugins/marvin/skills/quick-review",
      "./plugins/marvin/skills/redteam",
      "./plugins/marvin/skills/scaffold",
      "./plugins/marvin/skills/test-writer",
      "./plugins/quellis/skills/coach",
      "./plugins/quellis/skills/goal-checkin",
      "./plugins/quellis/skills/goal-setting",
      "./plugins/quellis/skills/reflect"
    ]
  }
}
